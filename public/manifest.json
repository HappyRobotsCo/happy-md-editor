{
  "manifest_version": 3,
  "name": "Happy MD Editor",
  "version": "1.0.0",
  "description": "The missing Chrome markdown editor — open, edit, and save .md files with a clean WYSIWYG interface.",
  "action": {
    "default_title": "Open Happy MD Editor",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "include_globs": ["*.md", "*.markdown"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
